    0.5, 0.0);\r\n    float3 heegnerColor = float3(2.0, 2.0, 2.0);\r\n\r\n    float3
    col = bulkColor;\r\n    col = nodeClass > 0.5  ? bifurColor   : col;\r\n    col
    = nodeClass > 1.5  ? heegnerColor : col;\r\n\r\n    col *= 1.0 + _BifurcationPulse
    * sin(time * 8.0) * 0.5;\r\n    col *= 1.0 + _HeegnerIntensity;\r\n\r\n    float
    psiSq = attributes.color.x;\r\n    attributes.color = float4(col, saturate(psiSq
    * 2.0));\r\n}"
