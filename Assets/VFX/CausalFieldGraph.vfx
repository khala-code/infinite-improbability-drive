  m_Name: 
  m_EditorClassIdentifier: Unity.VisualEffectGraph.Editor::UnityEditor.VFX.Block.CustomHLSL
  m_UIIgnoredErrors: []
  m_Parent: {fileID: 8926484042661615129}
  m_Children: []
  m_UIPosition: {x: 0, y: 402}
  m_UICollapsed: 0
  m_UISuperCollapsed: 0
  m_InputSlots:
  - {fileID: 8926484042661615308}
  - {fileID: 8926484042661615309}
  - {fileID: 8926484042661615310}
  m_OutputSlots: []
  m_Disabled: 0
  m_ActivationSlot: {fileID: 8926484042661615199}
  m_BlockName: Custom HLSL
  m_HLSLCode: "void CustomHLSL(inout VFXAttributes attributes, \r\n               
    in uint particleId,\r\n                in StructuredBuffer<float4> _CausalNodes,\r\n               
    in int _Resolution)\r\n{\r\n    uint nodeIndex = particleId % (uint)(_Resolution
    * _Resolution * _Resolution);\r\n    float4 nodeData = _CausalNodes[nodeIndex];\r\n\r\n   
    float psiSq     = nodeData.x;\r\n    float voidD     = nodeData.y;\r\n    float
    xi        = nodeData.z;\r\n    float nodeClass = nodeData.w;\r\n\r\n    attributes.lifetime
    = lerp(0.5, 3.0, xi) * (1.0 - voidD * 0.5);\r\n    attributes.size     = lerp(0.002,
    0.01, voidD);\r\n    attributes.velocity = normalize(attributes.position) * psiSq
    * 0.3;\r\n}"
  m_ShaderFile: {fileID: 0}
  m_AvailableFunction:
    selection: CustomHLSL
    selectedIndex: 0
