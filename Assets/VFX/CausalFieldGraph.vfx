  m_UIPosition: {x: 0, y: 2}
  m_UICollapsed: 0
  m_UISuperCollapsed: 0
  m_InputSlots:
  - {fileID: 8926484042661615311}
  - {fileID: 8926484042661615312}
  - {fileID: 8926484042661615313}
  m_OutputSlots: []
  m_Disabled: 0
  m_ActivationSlot: {fileID: 8926484042661615213}
  m_BlockName: Custom HLSL
  m_HLSLCode: "void CustomHLSL(inout VFXAttributes attributes,\r\n               
    in float _BifurcationPulse,\r\n                in float _HeegnerIntensity,\r\n               
    in float time)\r\n{\r\n    float nodeClass = attributes.color.w;\r\n\r\n    float3
    bulkColor    = float3(0.1, 0.2, 0.8);\r\n    float3 bifurColor   = float3(1.0,
    0.5, 0.0);\r\n    float3 heegnerColor = float3(2.0, 2.0, 2.0);\r\n\r\n    float3
    col = bulkColor;\r\n    col = nodeClass > 0.5  ? bifurColor   : col;\r\n    col
    = nodeClass > 1.5  ? heegnerColor : col;\r\n\r\n    col *= 1.0 + _BifurcationPulse
    * sin(time * 8.0) * 0.5;\r\n    col *= 1.0 + _HeegnerIntensity;\r\n\r\n    float
    psiSq = attributes.color.x;\r\n    attributes.color = float4(col, saturate(psiSq
    * 2.0));\r\n}"
  m_ShaderFile: {fileID: 0}
  m_AvailableFunction:
    selection: CustomHLSL
    selectedIndex: 0
