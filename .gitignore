# CMB pipeline outputs (reproducible from FITS via Python pipeline)
# Already-committed files: run `git rm -r --cached Assets/CMB/Processed/`
# then commit to stop tracking them.
Assets/CMB/Processed/*.npz
Assets/CMB/Processed/*.json
Assets/CMB/Processed/*.npy

# Large pre-baked textures (generated locally by Python pipeline)
Assets/CMB/Textures/*.exr

# StreamingAssets runtime outputs (generated by generate_particle_buffer.py)
# These are large binary files regenerated locally; not tracked in git.
Assets/StreamingAssets/CMB/particle_buffer.bin
Assets/StreamingAssets/CMB/epoch_frame.json

